# ── ShieldShift Environment Variables ──
# Copy this file to .env and fill in values before running

# Database (SQLite used by default in dev — no setup needed)
DATABASE_URL=sqlite:///./shieldshift_dev.db

# Set to "true" for demo/hackathon mode — simulates all payments
DEMO_MODE=true

# Razorpay (get free test keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_ACCOUNT_NUMBER=your_account_number

# Twilio (get free trial from twilio.com — includes ₹0 SMS credits)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE=+1234567890

# OpenWeatherMap (free tier — register at openweathermap.org)
OWM_API_KEY=your_key_here

# Frontend API URL (used by Vite)
VITE_API_URL=http://localhost:8000/api

# Mock APIs port
MOCK_API_PORT=4000
